# Copy to `.env` and adjust for your host:
#   cp .env.example .env
#
# Docker Compose loads this file automatically for variable substitution.
# ssi-indexer and ssi-chat also read it via pydantic-settings (repo root or service `.env`).

# ── Ollama (host ML — not containerized) ─────────────────────────────────────
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_EMBEDDING_MODEL=snowflake-arctic-embed:m
OLLAMA_CHAT_MODEL=llama3:8b

# Pull models before starting the stack:
#   ollama pull snowflake-arctic-embed:m
#   ollama pull llama3:8b
